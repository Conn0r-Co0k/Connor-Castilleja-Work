community %<>%
group_by(transect, segment) %>%
mutate(percent_cast = sum(cas_yn, TRUE)/ sum(cast_presence))
#---------------Look at proportion of castilleja in each segment----------#
community %<>%
group_by(transect, segment) %>%
mutate(percent_cast = sum(cas_yn, TRUE)/ sum(cast_presence))
View(community)
